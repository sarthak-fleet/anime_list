{
  "name": "mal",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "type": "module",
  "description": "",
  "scripts": {
    "dev": "concurrently -n be,fe -c blue,green \"pnpm dev:worker\" \"vite\"",
    "dev:be": "pnpm dev:worker",
    "dev:fe": "vite",
    "dev:worker": "wrangler dev --config wrangler.cron.toml",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "node -e \"const cp=require('child_process');const branch=cp.execSync('git branch --show-current',{encoding:'utf8'}).trim();const dirty=cp.execSync('git status --porcelain',{encoding:'utf8'}).trim(); if(branch!=='main'||dirty){console.error('deploy: must be on clean main branch (current:',branch, dirty?'dirty tree':''); process.exit(1);} console.log('deploy: clean main confirmed');\" && pnpm build && wrangler pages deploy dist --project-name=anime-list --branch=main",
    "lint": "eslint src components lib",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:anime-detail": "playwright test e2e/anime-detail.spec.ts",
    "db:seed": "tsx src/scripts/seedAnimeData.ts",
    "db:seed:manga": "tsx src/scripts/seedMangaData.ts",
    "db:update": "tsx src/scripts/updateAnimeData.ts",
    "db:update:manga": "tsx src/scripts/updateMangaData.ts",
    "db:update:manga:full": "tsx src/scripts/updateMangaData.ts -- --full",
    "db:quarterly-sync": "tsx src/scripts/runQuarterlyAnimeSync.ts",
    "deploy:worker": "wrangler deploy src/worker.ts --config wrangler.cron.toml",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fontsource/inter": "5.2.5",
    "@libsql/client": "0.17.3",
    "@tanstack/react-query": "5.100.1",
    "@tanstack/react-router": "1.120.12",
    "axios": "1.15.2",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "dotenv": "17.4.2",
    "hono": "4.12.15",
    "jose": "6.2.2",
    "lucide-react": "1.11.0",
    "nuqs": "2.8.9",
    "pino": "10.3.1",
    "posthog-js": "^1.372.1",
    "radix-ui": "1.4.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4",
    "tsx": "4.21.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@cloudflare/workers-types": "4.20260424.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.59.1",
    "@saas-maker/prettier-config": "1.0.0",
    "@saas-maker/test-config": "^0.2.0",
    "@saas-maker/tsconfig": "1.0.0",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19",
    "@types/react-dom": "19",
    "@vitejs/plugin-react": "6.0.1",
    "@vitejs/plugin-react-swc": "4.3.0",
    "concurrently": "9.2.1",
    "eslint": "9.36.0",
    "husky": "9.1.7",
    "jsdom": "^29.0.0",
    "pino-pretty": "13.1.3",
    "shadcn": "4.4.0",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.0",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "wrangler": "4.85.0"
  },
  "prettier": "@saas-maker/prettier-config"
}